ধরি ক = ০
যতক্ষণ ক < ৩ করো
    ধরি খ = ০
    যতক্ষণ খ < ৩ করো
        ধরি গ = ০
        যতক্ষণ গ < ৩ করো
            ধরি ঘ = ০
            যতক্ষণ ঘ < ৩ করো
                দেখাও(ক, " ", খ, " ", গ, " ", ঘ, "\n")
                ঘ = ঘ + ১
            শেষ
            গ = গ + ১
        শেষ
        খ = খ + ১
    শেষ
    ক = ক + ১
শেষ
